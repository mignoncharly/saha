# ---------------------------------------------------------------------------
# SAHA Transport & Logistics – environment configuration
# Copy this file to `.env` and replace the placeholder values.
# NEVER commit the real `.env` file (see .gitignore).
# ---------------------------------------------------------------------------

# Which settings module Django loads (config.settings.local | config.settings.production)
DJANGO_SETTINGS_MODULE=config.settings.local

# Django core
# Generate a new key, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
FRONTEND_URL=http://localhost:3000

# PostgreSQL (used by docker-compose to provision the database container)
POSTGRES_DB=stl_db
POSTGRES_USER=stl_user
POSTGRES_PASSWORD=change-me-postgres-password

# Database / cache connection strings consumed by Django
# Keep the password here in sync with POSTGRES_PASSWORD above.
DATABASE_URL=postgres://stl_user:change-me-postgres-password@postgres:5432/stl_db
REDIS_URL=redis://redis:6379/0

# CORS – comma separated list of allowed front-end origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Email
# Local/dev: console backend prints emails to the server log.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=STL <info@gestionatech.de>
# Production SMTP (only used by config.settings.production)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Web Push (VAPID) keys.
# Generate with:  python -c "from py_vapid import Vapid01; v=Vapid01(); v.generate_keys(); print(v.private_key, v.public_key)"
# or use the web-push CLI. The public key must also be exposed to the frontend.
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=admin@example.com

# Media files
MEDIA_URL=/media/
MEDIA_ROOT=/app/media

# Data retention
# Daily Celery beat purge deletes photos on terminal requests older than this many days.
DATA_RETENTION_DAYS=365
# Customer PII anonymization is available but opt-in because it rewrites customer records.
DATA_RETENTION_ANONYMIZE_CUSTOMERS=False

# ---------------------------------------------------------------------------
# Frontend (Next.js) – variables prefixed with NEXT_PUBLIC_ are exposed to the browser
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_WHATSAPP_NUMBER=+4917684440384
