[Unit]
Description=SAHA-STL Django API (gunicorn)
After=network.target postgresql.service saha-redis.service
Wants=saha-redis.service

[Service]
User=mignon
Group=mignon
WorkingDirectory=/home/mignon/saha/backend
Environment=DJANGO_SETTINGS_MODULE=config.settings.production
ExecStart=/home/mignon/saha/backend/.venv/bin/gunicorn config.wsgi:application --bind 127.0.0.1:8030 --workers 3 --timeout 120
Restart=always
RestartSec=5
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
